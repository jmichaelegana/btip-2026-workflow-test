profiles {
    local {
        process.executor = 'local'
    }
    slurm {
        process {
            executor       = 'slurm'
            clusterOptions = '--reservation=btip2026'
            beforeScript   = "bash -c 'export PATH=\$HOME/.pixi/bin:${launchDir}/.pixi/envs/default/bin:\$PATH; eval \"\$(pixi shell-hook -s bash --manifest-path ${launchDir}/pixi.toml --frozen)\"'"
        }
        executor {
            queueSize = 10
        }
    }
    slurm_jcegana {
        process {
            executor       = 'slurm'
            clusterOptions = '--account=cfb --partition=cfb'
            beforeScript   = "bash -c 'export PATH=\$HOME/.pixi/bin:${launchDir}/.pixi/envs/default/bin:\$PATH; eval \"\$(pixi shell-hook -s bash --manifest-path ${launchDir}/pixi.toml --frozen)\"'"
        }
        executor {
            queueSize = 10
        }
    }
}

// All tools (fastp, spades, quast) are installed via pixi into .pixi/envs/default/bin/
// Local execution: env.PATH prepends the pixi bin directory.
// SLURM execution: beforeScript runs pixi shell-hook on each compute node,
// fully activating the pixi environment (PATH, CONDA_PREFIX, libs, etc.).
// --frozen avoids lock-file updates inside SLURM job scripts.
env {
    PATH = "${launchDir}/.pixi/envs/default/bin:${PATH}"
}

process {
    cpus   = 1
    memory = '2 GB'
    time   = '5 min'

    withName: TRIM      { cpus = 1 }
    withName: ASSEMBLE  { cpus = 1; memory = '2 GB'; maxForks = 2 }
    withName: EVALUATE  { cpus = 1; maxForks = 2 }
}

dag {
    enabled = true
    file    = "results/nextflow/dag.svg"
}

timeline {
    enabled = true
    file    = "results/nextflow/timeline.html"
}

report {
    enabled = true
    overwrite = true
    file    = "results/nextflow/report.html"
}
